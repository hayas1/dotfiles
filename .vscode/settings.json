{
    "[python]": {
        "editor.tabSize": 4,
        "editor.detectIndentation": false,
        "editor.formatOnSave": true,
    },
    "python.formatting.provider": "black",
    "python.formatting.blackArgs": [
        "--line-length=120"
    ],
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": false,
    "python.linting.flake8Enabled": true,
    "python.linting.lintOnSave": true,
    "python.linting.flake8Args": [
        "--max-line-length=120",
    ],
    "cSpell.words": [
        "atexit",
        "azuretools",
        "batcat",
        "cloudcode",
        "CLOUDSDK",
        "codespaces",
        "copylist",
        "devc",
        "devcinit",
        "devcontainer",
        "devcontainers",
        "dotfiles",
        "dups",
        "eamodio",
        "fdfind",
        "foxundermoon",
        "fpath",
        "gcloud",
        "googlecloudtools",
        "Gruntfuggly",
        "keyrings",
        "kohler",
        "mhutchie",
        "mktemp",
        "nerdfont",
        "noninteractive",
        "noreply",
        "powerlevel",
        "powerline",
        "procs",
        "PTRACE",
        "purepower",
        "rangav",
        "realpath",
        "ripgrep",
        "SAVEHIST",
        "seccomp",
        "setopt",
        "shardulm",
        "shellcheck",
        "timonwong",
        "yzhang"
    ]
}